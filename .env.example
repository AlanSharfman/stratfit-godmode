# ═══════════════════════════════════════════════════════════════
# STRATFIT — Environment Variables
# Copy to .env.local for local development
# ═══════════════════════════════════════════════════════════════

# ── AI Integration ──
# Optional: enables OpenAI-powered Q&A and force mapping.
# If unset, falls back to local NLP engine.
VITE_OPENAI_API_KEY=
VITE_OPENAI_ENDPOINT=https://api.openai.com/v1/chat/completions

# ── Feature Flags ──
# Set to "true" to enable beta features (default: all disabled)
VITE_FF_COLLABORATION=false
VITE_FF_AI_FORCE_MAPPER=false
VITE_FF_WEBHOOKS=false
VITE_FF_NETWORK_INTELLIGENCE=true

# ── App Config ──
VITE_APP_VERSION=0.1.0
VITE_ANALYTICS_ID=
